rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    // Tasks: users can only access their own tasks
    match /tasks/{taskId} {
      allow read: if isDocOwner();

      allow create: if isAuthenticated()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && request.resource.data.priority in ['High', 'Medium', 'Low']
                    && request.resource.data.status in ['Pending', 'Scheduled', 'In Progress', 'Completed'];

      allow update: if isDocOwner()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.priority in ['High', 'Medium', 'Low']
                    && request.resource.data.status in ['Pending', 'Scheduled', 'In Progress', 'Completed'];

      allow delete: if isDocOwner();
    }

    // Users collection (future use)
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // Deny all other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
